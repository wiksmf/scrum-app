generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum Role {
  ADMIN
  MEMBER
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum StoryStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Auth Tables (NextAuth) ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts            Account[]
  sessions            Session[]
  memberships         OrganizationMember[]
  assignedStories     Story[]              @relation("Assignee")
  pokerVotes          PokerVote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Tables ───────────────────────────────────────────────────────────────

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  plan             Plan     @default(FREE)
  stripeCustomerId String?
  createdAt        DateTime @default(now())

  members     OrganizationMember[]
  projects    Project[]
  invitations Invitation[]
}

model OrganizationMember {
  userId         String
  organizationId String
  role           Role     @default(MEMBER)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sprints      Sprint[]
  stories      Story[]
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime
  endDate   DateTime
  projectId String
  createdAt DateTime     @default(now())

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories       Story[]
  pokerSessions PokerSession[]
}

model Story {
  id                 String      @id @default(cuid())
  title              String
  description        String?
  acceptanceCriteria String?
  status             StoryStatus @default(TODO)
  priority           Priority    @default(MEDIUM)
  points             Int?
  order              Int         @default(0)
  projectId          String
  sprintId           String?
  assigneeId         String?
  createdAt          DateTime    @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint       Sprint?       @relation(fields: [sprintId], references: [id])
  assignee     User?         @relation("Assignee", fields: [assigneeId], references: [id])
  attachments  Attachment[]
  pokerSession PokerSession?
}

model Attachment {
  id         String   @id @default(cuid())
  url        String
  name       String
  storyId    String
  uploadedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model PokerSession {
  id        String   @id @default(cuid())
  storyId   String   @unique
  sprintId  String
  revealed  Boolean  @default(false)
  createdAt DateTime @default(now())

  story  Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sprint Sprint      @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  votes  PokerVote[]
}

model PokerVote {
  id        String @id @default(cuid())
  sessionId String
  userId    String
  value     Int

  session PokerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  organizationId String
  token          String   @unique
  expires        DateTime
  accepted       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}